# GrantPilot Environment Variables
# Copy this to .env and fill in your values

# === REQUIRED ===
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# === AUTH PROVIDERS (at least one required) ===
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# === AI (required for Smart Fill, Grant Analysis, Essay Generation) ===
ANTHROPIC_API_KEY=""

# === PAYMENTS (required for subscriptions + success fees) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_GROWTH_PRICE_ID=""
STRIPE_GROWTH_ANNUAL_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""
STRIPE_ORG_PRICE_ID=""
STRIPE_ORG_ANNUAL_PRICE_ID=""

# === EMAIL (required for alerts, digests, reminders) ===
RESEND_API_KEY=""
RESEND_FROM_EMAIL="GrantPilot <hello@yourdomain.com>"

# === CRON (required for automated scraping + alerts) ===
CRON_SECRET="generate-a-random-secret-here"

# === OPTIONAL ===
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
SAM_GOV_API_KEY=""
SIMPLER_GRANTS_GOV_API_KEY=""
